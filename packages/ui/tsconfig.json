{
    "compilerOptions": {
        "jsx": "react-native",
        "moduleResolution": "node",
        "baseUrl": ".",
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@area/*": [
                "../../src/*"
            ]
        },
        "types": [
            "react",
            "react-native"
        ],
        "skipLibCheck": true
    },
    "include": [
        "src/**/*"
    ]
}
